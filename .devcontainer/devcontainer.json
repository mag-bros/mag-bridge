{
  "name": "Claude Isolation",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--shm-size=1g"
  ],
  "mounts": [
    "source=${localWorkspaceFolderBasename}-history,target=/commandhistory,type=volume",
    "source=${localWorkspaceFolder}/.devcontainer/dotfiles/.p10k.zsh,target=/home/vscode_server/.p10k.zsh,type=bind",
    "source=${localWorkspaceFolderBasename}-claude-config,target=/home/vscode_server/.claude,type=volume"
  ],
  "overrideCommand": true,
  "hostRequirements": {
    "memory": "3gb"
  },
  "forwardPorts": [
    4200,
    8000
  ],
  "portsAttributes": {
    "4200": {
      "label": "Angular Frontend",
      "onAutoForward": "silent"
    },
    "8000": {
      "label": "FastAPI Backend",
      "onAutoForward": "silent"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "username": "vscode_server",
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nodeGypDependencies": false
    }
  },
  "remoteUser": "vscode_server",
  "remoteEnv": {
    "PATH": "${containerWorkspaceFolder}/.devcontainer/node_modules/.bin:${containerWorkspaceFolder}/.venv/bin:${containerEnv:PATH}",
    "UV_LINK_MODE": "copy",
    "HISTFILE": "/commandhistory/.zsh_history"
  },
  "customizations": {
    "vscode": {
      "settings": {
        // --- Editor & Workbench (Global UI) ---
        "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
        "editor.detectIndentation": true,
        "editor.insertSpaces": true,
        "editor.largeFileOptimizations": false,
        "editor.minimap.enabled": false,
        "editor.tabSize": 2,
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "explorer.confirmDelete": false,
        "explorer.confirmDragAndDrop": false,
        "launch": {
          "justMyCode": false
        },
        "workbench.colorCustomizations": {},
        "workbench.secondarySideBar.defaultVisibility": "hidden",
        "workbench.startupEditor": "none",
        // --- Terminal & Shell ---
        "remote.autoForwardPorts": false,
        "terminal.integrated.enableMultiLinePasteWarning": "never",
        "terminal.integrated.env.osx": {
          "PYTHONPATH": "${workspaceFolder}"
        },
        "terminal.integrated.environmentChangesRelaunch": true,
        "terminal.integrated.fontFamily": "'MesloLGS NF'",
        // --- Files & Git ---
        "files.associations": {
          "*.sh": "shellscript"
        },
        "files.autoSave": "onFocusChange",
        "files.exclude": {},
        "files.watcherExclude": {},
        "git.defaultBranchName": "master",
        "git.openRepositoryInParentFolders": "never",
        "gitlens.graph.layout": "editor",
        // --- AI (Claude & Chat) ---
        "chat.hookFilesLocations": {
          "~/.claude/settings.json": false
        },
        "chat.useClaudeHooks": true,
        "claudeCode.environmentVariables": [
          {
            "name": "PYTHONPATH",
            "value": "${workspaceFolder}:${workspaceFolder}/src:${workspaceFolder}/tests"
          }
        ],
        "claudeCode.preferredLocation": "sidebar",
        "claudeCode.selectedModel": "default",
        // --- Python, Jupyter & Testing ---
        "jupyter.askForKernelRestart": false,
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "python.analysis.autoImportCompletions": true,
        "python.analysis.indexing": true,
        "python.analysis.languageServerMode": "full",
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.languageServer": "Pylance",
        "python.terminal.useEnvFile": true,
        "python.testing.pytestArgs": [
          "tests",
          ".devcontainer/tests"
        ],
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.terminal.activateEnvironment": false,
        "ruff.configuration": "${workspaceFolder}/pyproject.toml",
        // --- Extensions & Utilities ---
        "evenBetterToml.schema.associations": {
          "tox.toml": "null"
        },
        "latex-workshop.view.pdf.viewer": "tab",
        "resmon.show.battery": false,
        "resmon.show.cpufreq": false,
        // --- Language-Specific Overrides ---
        "[css]": {
          "editor.formatOnSave": true
        },
        "[dotenv]": {
          "editor.formatOnSave": true
        },
        "[html]": {
          "editor.formatOnSave": true
        },
        "[javascript]": {
          "editor.formatOnSave": true
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[jsonc]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "vscode.json-language-features"
        },
        "[markdown]": {
          "editor.defaultFormatter": "vscode.markdown-language-features",
          "editor.formatOnSave": true,
          "editor.tabSize": 4,
          "editor.insertSpaces": true
        },
        "[python]": {
          "editor.formatOnSave": true,
          "editor.tabSize": 4,
          "editor.formatOnType": true,
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.organizeImports.ruff": "explicit",
            "source.fixAll.ruff": "explicit"
          }
        },
        "[scss]": {
          "editor.formatOnSave": true
        },
        "[shellscript]": {
          "editor.formatOnSave": true
        },
        "[toml]": {
          "editor.formatOnSave": true,
          "editor.tabSize": 4,
          "editor.insertSpaces": true
        },
        "[typescript]": {
          "editor.formatOnSave": true
        },
        "[yaml]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        // --- Theme Cycling (Sync) ---
        "settings.cycle": [
          {
            "id": "CustomThemes",
            "values": [
              {
                "note": "Cyber Punk",
                "workbench.colorCustomizations": {
                  "statusBar.background": "#8700ff",
                  "statusBar.foreground": "#ffff00",
                  "diffEditor.insertedTextBackground": "#005fff33",
                  "diffEditor.removedTextBackground": "#ff00df33"
                }
              },
              {
                "note": "Forest Mist",
                "workbench.colorCustomizations": {
                  "statusBar.background": "#005f00",
                  "statusBar.foreground": "#ffffff",
                  "diffEditor.insertedTextBackground": "#5f875f33",
                  "diffEditor.removedTextBackground": "#005f0033"
                }
              },
              {
                "note": "Slate Fire",
                "workbench.colorCustomizations": {
                  "statusBar.background": "#1c1c1c",
                  "statusBar.foreground": "#ffaf00",
                  "diffEditor.insertedTextBackground": "#d7000033",
                  "diffEditor.removedTextBackground": "#1c1c1c33"
                }
              }
            ]
          }
        ]
      },
      "extensions": [
        "angular.ng-template",
        "anthropic.claude-code",
        "bierner.github-markdown-preview",
        "charliermarsh.ruff",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "tamasfe.even-better-toml",
        "ionutvmi.path-autocomplete",
        "james-yu.latex-workshop",
        "mechatroner.rainbow-csv",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-vscode.test-adapter-converter",
        "ms-vscode.vscode-typescript-next",
        "mutantdino.resourcemonitor",
        "oderwat.indent-rainbow",
        "postman.postman-for-vscode",
        "redhat.vscode-yaml",
        "hoovercj.vscode-settings-cycler"
      ]
    }
  },
  "updateContentCommand": "bash .devcontainer/updateContentCommand.sh",
  "onCreateCommand": "echo '==> [Lifecycle: onCreateCommand] Base OS built. Workspace not mounted yet.'",
  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
  "postStartCommand": "echo '==> [Lifecycle: postStartCommand] Container awake.'"
}