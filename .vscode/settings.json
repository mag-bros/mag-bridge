{
  "python.terminal.activateEnvironment": false,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.detectIndentation": true,
  "editor.insertSpaces": true,
  "editor.largeFileOptimizations": false,
  "editor.minimap.enabled": false,
  "editor.tabSize": 2,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "launch": {
    "justMyCode": false
  },
  "workbench.colorCustomizations": {},
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.startupEditor": "none",
  "remote.autoForwardPorts": false,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.env.osx": {
    "PYTHONPATH": "${workspaceFolder}"
  },
  "terminal.integrated.environmentChangesRelaunch": true,
  "terminal.integrated.fontFamily": "'MesloLGS NF'",
  "files.associations": {
    "*.sh": "shellscript"
  },
  "files.autoSave": "onFocusChange",
  "files.exclude": {},
  "files.watcherExclude": {},
  "git.defaultBranchName": "master",
  "git.openRepositoryInParentFolders": "never",
  "gitlens.graph.layout": "editor",
  "chat.hookFilesLocations": {
    "~/.claude/settings.json": false
  },
  "chat.useClaudeHooks": true,
  "claudeCode.environmentVariables": [
    {
      "name": "PYTHONPATH",
      "value": "${workspaceFolder}:${workspaceFolder}/src:${workspaceFolder}/tests"
    }
  ],
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.selectedModel": "default",
  "jupyter.askForKernelRestart": false,
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.indexing": true,
  "python.analysis.languageServerMode": "full",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.languageServer": "Pylance",
  "python.terminal.useEnvFile": true,
  "python.testing.pytestArgs": [
    "tests",
    ".devcontainer/tests/test_ai_isolation.py"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "ruff.configuration": "${workspaceFolder}/pyproject.toml",
  "evenBetterToml.schema.associations": {
    "tox.toml": "null"
  },
  "latex-workshop.view.pdf.viewer": "tab",
  "resmon.show.battery": false,
  "resmon.show.cpufreq": false,
  "[css]": {
    "editor.formatOnSave": true
  },
  "[dotenv]": {
    "editor.formatOnSave": true
  },
  "[html]": {
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "vscode.markdown-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[python]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.formatOnType": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },
  "[scss]": {
    "editor.formatOnSave": true
  },
  "[shellscript]": {
    "editor.formatOnSave": true
  },
  "[toml]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[typescript]": {
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "settings.cycle": [
    {
      "id": "CustomThemes",
      "values": [
        {
          "note": "Cyber Punk",
          "workbench.colorCustomizations": {
            "statusBar.background": "#8700ff",
            "statusBar.foreground": "#ffff00",
            "diffEditor.insertedTextBackground": "#005fff33",
            "diffEditor.removedTextBackground": "#ff00df33"
          }
        },
        {
          "note": "Forest Mist",
          "workbench.colorCustomizations": {
            "statusBar.background": "#005f00",
            "statusBar.foreground": "#ffffff",
            "diffEditor.insertedTextBackground": "#5f875f33",
            "diffEditor.removedTextBackground": "#005f0033"
          }
        },
        {
          "note": "Slate Fire",
          "workbench.colorCustomizations": {
            "statusBar.background": "#1c1c1c",
            "statusBar.foreground": "#ffaf00",
            "diffEditor.insertedTextBackground": "#d7000033",
            "diffEditor.removedTextBackground": "#1c1c1c33"
          }
        }
      ]
    }
  ]
}