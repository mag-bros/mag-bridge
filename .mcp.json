{
  "mcpServers": {
    "codebase-memory": {
      "type": "stdio",
      "command": "/usr/local/bin/codebase-memory-mcp",
      "args": []
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@2.2.5"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_TOKEN}"
      }
    },
    "repomix": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "repomix@1.14.0", "--mcp"]
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp@0.2.19"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "exa": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "exa-mcp-server@3.2.1"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "pdf-reader": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@sylphx/pdf-reader-mcp@2.4.0", "--no-http"]
    }
  }
}
