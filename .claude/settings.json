{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ./.claude/hooks/lint.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/play_sound.py .claude/sounds/Glass.wav"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/play_sound.py .claude/sounds/Basso.wav"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Read",
      "LS",
      "Grep",
      "Glob",
      "Bash(python -m pytest *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git status *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__github__search_repositories",
      "mcp__github__search_code",
      "mcp__github__get_file_contents",
      "mcp__github__get_repository",
      "mcp__github__list_repositories",
      "mcp__github__list_issues",
      "mcp__github__get_issue",
      "mcp__github__list_pull_requests",
      "mcp__github__get_pull_request",
      "mcp__github__list_branches",
      "mcp__github__get_branch",
      "mcp__github__list_commits",
      "mcp__github__get_commit",
      "mcp__repomix__attach_packed_output",
      "mcp__repomix__file_system_read_directory",
      "mcp__repomix__file_system_read_file",
      "mcp__repomix__grep_repomix_output",
      "mcp__repomix__read_repomix_output"
    ],
    "deny": [
      "Read(//**)",
      "Read(~/**)",
      "Edit(//**)",
      "Edit(~/**)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push -f *)",
      "Bash(git reset *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(mkfs *)",
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(wget *)",
      "Bash(curl *)",
      "Bash(dd *)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/.env*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)"
    ]
  },
  "telemetry": {
    "enabled": false,
    "otlp": {
      "endpoint": "http://0.0.0.0:4317",
      "protocol": "grpc"
    }
  }
}